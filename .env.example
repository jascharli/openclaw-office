# 龙虾办公室 - 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ==================== 端口配置 ====================

# 后端 API 端口（默认：8000）
LOBSTER_BACKEND_PORT=8000

# 前端页面端口（默认：5173）
LOBSTER_FRONTEND_PORT=5173

# 监听地址（默认：0.0.0.0，允许所有网络接口）
LOBSTER_HOST=0.0.0.0

# ==================== Token 预算 ====================

# 日预算 Token（默认：500000）
LOBSTER_TOKEN_BUDGET_DAILY=500000

# 月预算 Token（默认：10000000）
LOBSTER_TOKEN_BUDGET_MONTHLY=10000000

# ==================== 飞书配置（可选） ====================

# 飞书 Webhook URL（用于发送督促通知）
FEISHU_WEBHOOK_URL=

# 飞书 App ID
FEISHU_APP_ID=

# 飞书 App Secret
FEISHU_APP_SECRET=

# ==================== 数据库配置 ====================

# 数据库文件路径
LOBSTER_DB_PATH=./backend/lobster_office.db

# 时区
LOBSTER_TIMEZONE=Asia/Shanghai

# ==================== 其他配置 ====================

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOBSTER_LOG_LEVEL=INFO

# 是否启用自动督促（true/false）
LOBSTER_AUTO_REMINDER=true

# Agent 扫描目录
LOBSTER_AGENTS_SCAN_DIR=~/.openclaw/agents
